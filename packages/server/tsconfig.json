{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "noEmit": true,
    // We're using a bundler (tsdown) even for the server so we can avoid the
    // .js extension in imports
    "types": [
      "node"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler"
  },
  "include": [
    "src/**/*",
    "__tests__/**/*",
    "tests/**/*",
    "migrations/**/*"
  ]
}