{
  "name": "my-project",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0",
  "description": "Starter template for TypeScript projects",
  "main": "index.js",
  "scripts": {
    "build": "turbo run build",
    "build:watch": "pnpm -r --if-present run build:watch",
    "clean": "pnpm -r --if-present run clean",
    "start:server": "pnpm --filter @my-project/server run start",
    "start:client": "pnpm --filter @my-project/client run start",
    "dev": "pnpm -r --if-present run dev",
    "test": "turbo run test",
    "test:watch": "pnpm -r --if-present run test:watch",
    "test:coverage": "pnpm -r --if-present run test:coverage",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "turbo run typecheck",
    "audit": "pnpm -r --if-present run audit",
    "audit:fix": "pnpm -r --if-present run audit:fix",
    "audit:fix-force": "pnpm -r --if-present run audit:fix-force"
  },
  "author": "Michael Martin",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@trivago/prettier-plugin-sort-imports": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "globals": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "tsup": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
