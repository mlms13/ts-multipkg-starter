{
  "name": "@my-project/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.mjs",
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "clean": "rm -rf dist",
    "start": "node dist/index.mjs",
    "dev": "tsdown --watch & node dist/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" --fix",
    "format": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "audit": "pnpm audit --audit-level=moderate",
    "audit:fix": "pnpm audit fix",
    "audit:fix-force": "pnpm audit fix --force"
  },
  "dependencies": {
    "@my-project/library": "workspace:*",
    "dotenv": "catalog:",
    "fastify": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:"
  }
}
